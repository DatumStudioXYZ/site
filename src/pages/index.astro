---
import Layout from "../layouts/Layout.astro";

const services = [
  ["01", "Work Better", "Home offices, studios, and workshops designed around focus, flow, and the tools you actually use."],
  ["02", "Live Better", "Storage, kitchens, mudrooms, and living spaces that remove friction from everyday routines."],
  ["03", "Build Better", "Custom millwork, built-ins, and furniture made with honest materials and a long working life."],
  ["04", "Think Better", "Planning, automation, workflow, and systems consulting that makes the whole project clearer."],
];

const steps = [
  ["Understand", "We begin with people: how you live, where friction appears, and what a better day should feel like."],
  ["Establish", "We find the reference point—the priorities and constraints against which every decision is measured."],
  ["Integrate", "Space, objects, materials, and technology are developed as one system rather than separate products."],
  ["Refine", "We build, test, document, and simplify until the result feels natural, durable, and easy to maintain."],
];

const values = [
  ["Intentional", "Every decision has a purpose."],
  ["Integrated", "Nothing exists in isolation."],
  ["Timeless", "Designed to outlive trends."],
  ["Human", "Technology serves people."],
  ["Crafted", "Built with care. Built to last."],
];
---

<Layout
  title="Datum Studio | Everything begins with a reference point"
  description="Datum creates thoughtful spaces, objects, and systems around the way people actually live. Architecture, craft, and technology for the Golden Horseshoe, GTA, Muskoka, and remote."
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      name: "Datum Studio",
      url: "https://datumstudio.xyz",
      description: "Design studio working across architecture, craftsmanship, technology, and systems thinking.",
      email: "hello@livingsystems.studio",
      areaServed: ["Golden Horseshoe", "GTA", "Muskoka"],
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Datum Studio Services",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Work Better",
              description: "Home offices, studios, and workshops designed around focus, flow, and the tools you actually use.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Live Better",
              description: "Storage, kitchens, mudrooms, and living spaces that remove friction from everyday routines.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Build Better",
              description: "Custom millwork, built-ins, and furniture made with honest materials and a long working life.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Think Better",
              description: "Planning, automation, workflow, and systems consulting that makes the whole project clearer.",
            },
          },
        ],
      },
    },
  ]}
>
  <section class="hero" id="top">
    <div class="hero-copy">
      <p class="eyebrow">Architecture · Craft · Technology</p>
      <h1>Everything begins with a reference point.</h1>
      <p class="hero-intro">Datum creates thoughtful spaces, objects, and systems around the way people actually live.</p>
      <div class="hero-actions">
        <a class="button button-primary" href="#contact">Start a conversation <span>↗</span></a>
        <a class="text-link" href="#about">Why Datum <span>↓</span></a>
      </div>
      <p class="location"><span></span> Golden Horseshoe · GTA · Muskoka · Remote</p>
    </div>
    <figure class="hero-image technical-frame">
      <img src="https://images.datumstudio.xyz/workshop-wide.jpeg" alt="A residential workshop being studied before redesign and organization" />
      <figcaption>Existing conditions · Workshop study</figcaption>
    </figure>
  </section>

  <section class="datum-story section-pad" id="about">
    <div class="story-heading">
      <p class="section-kicker">About Datum</p>
      <h2>The invisible line that makes everything fit.</h2>
    </div>
    <div class="story-copy">
      <p>Most people never notice the datum. They notice the finished building, the beautiful furniture, the calm home, or the software that simply works.</p>
      <p>In architecture, engineering, and surveying, a datum is the line, plane, or point from which everything else is measured. When the datum is right, every decision becomes clearer. Every component fits. Every detail supports the whole.</p>
      <p>We begin the same way: by understanding how people want to live. Only then do we bring together architecture, craftsmanship, technology, and systems thinking into something intentional, adaptable, and quietly beautiful.</p>
      <p class="story-close">Because the best design is often not the thing you notice. It is the thing that makes life feel effortless.</p>
    </div>
  </section>

  <section class="manifesto section-pad">
    <p class="section-kicker">Our reference point</p>
    <p class="manifesto-copy">Understand the person.<br /><em>Then design the whole.</em></p>
  </section>

  <section class="services section-pad" id="services">
    <div class="section-heading">
      <p class="section-kicker">What we do</p>
      <h2>Defined by outcomes,<br />not trades.</h2>
      <p>One studio thinking across the room, the object, and the technology inside it.</p>
    </div>
    <div class="service-grid">
      {services.map(([number, title, text]) => (
        <article class="service-card">
          <span class="service-number">{number}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="project section-pad" id="project">
    <div class="project-title">
      <div>
        <p class="section-kicker">Project · 01 · In progress</p>
        <h2>A workshop with a clear point of reference.</h2>
      </div>
      <p>The problem is not simply clutter. It is a room without a system—tools without homes, storage without memory, and valuable floor space buried beneath competing needs.</p>
    </div>
    <div class="project-gallery">
      <figure class="project-main technical-frame">
        <a href="/projects/workshop/">
          <img src="https://images.datumstudio.xyz/workshop-floor.jpeg" alt="Open floor area emerging during a garage workshop reorganization" />
          <figcaption>Establishing the working floor</figcaption>
        </a>
      </figure>
      <div class="project-side">
        <figure class="technical-frame">
          <img src="https://images.datumstudio.xyz/workshop-storage.jpeg" alt="Tools and storage awaiting a new organized system" />
          <figcaption>Inventory before infrastructure</figcaption>
        </figure>
        <div class="project-note">
          <span class="status"><i></i> Design in progress</span>
          <p>The system combines task zones, overhead tire storage, opaque labelled totes, and a searchable QR inventory—physical order with a digital memory.</p>
          <a href="/projects/workshop/" class="project-case-link">View case study <span>&rarr;</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="process section-pad" id="process">
    <div class="section-heading light">
      <p class="section-kicker">Our process</p>
      <h2>Find the datum.<br />Design from there.</h2>
    </div>
    <ol class="process-list">
      {steps.map(([title, text], index) => (
        <li>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="values section-pad">
    <div class="section-heading">
      <p class="section-kicker">Datum is</p>
      <h2>Five words to measure our work against.</h2>
    </div>
    <div class="values-grid">
      {values.map(([title, text], index) => (
        <article class="value-card">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="principles section-pad">
    <p class="section-kicker">Our promises</p>
    <div class="principle-list">
      <p>Simplicity over complexity.</p>
      <p>Function before decoration.</p>
      <p>Technology that disappears.</p>
      <p>Craftsmanship that lasts.</p>
      <p>Systems that can evolve.</p>
    </div>
  </section>

  <section class="contact section-pad" id="contact">
    <div class="contact-copy">
      <p class="section-kicker">Start a conversation</p>
      <h2>What would make life work better?</h2>
      <p>Tell us about the space, routine, object, or stubborn problem. Early ideas are welcome; you do not need a finished brief.</p>
      <p class="contact-meta">Serving the Golden Horseshoe, GTA, Muskoka, and remote projects.</p>
    </div>
    <form class="contact-form">
      <div class="field-row">
        <label><span>Name</span><input name="name" type="text" autocomplete="name" required placeholder="Your name" /></label>
        <label><span>Email</span><input name="email" type="email" autocomplete="email" required placeholder="you@example.com" /></label>
      </div>
      <div aria-hidden="true" class="honeypot">
        <label>Leave this empty<input name="website" type="text" tabindex="-1" autocomplete="off" /></label>
      </div>
      <label><span>Tell us what is not working</span><textarea name="message" required rows="5" placeholder="A few sentences is plenty…"></textarea></label>
      <div class="cf-turnstile" data-sitekey="0x4AAAAAAD4t1xClM1TPKrEM"></div>
      <button class="button button-primary submit" type="submit">Send message <span>↗</span></button>
      <p class="form-note" aria-live="polite">We typically respond within 2 business days.</p>
    </form>
  </section>

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script>
    const form = document.querySelector<HTMLFormElement>(".contact-form");
    const button = form?.querySelector<HTMLButtonElement>("button[type='submit']");
    const note = form?.querySelector<HTMLElement>(".form-note");

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const data = new FormData(form);
      if (data.get("website")) return;

      if (button) {
        button.disabled = true;
        button.innerHTML = "Sending… <span>↻</span>";
      }

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          body: data,
        });

        const result = await response.json() as { ok?: boolean; error?: string };

        if (result.ok) {
          window.location.href = "/thank-you";
        } else {
          throw new Error(result.error || "Failed to send");
        }
      } catch (error) {
        if (note) note.textContent = "Something went wrong. Please try again or email us directly at hello@livingsystems.studio.";
        console.error("Contact form error:", error);
      } finally {
        if (button) {
          button.disabled = false;
          button.innerHTML = "Send message <span>↗</span>";
        }
      }
    });
  </script>
</Layout>
