---
import Layout from "../../layouts/Layout.astro";

const services = [
  {
    number: "01",
    title: "Work Better",
    tagline: "Home offices, studios, and workshops designed around focus, flow, and the tools you actually use.",
    description: "Your workspace should disappear into the work. We design rooms where every tool has a home, every surface earns its place, and the environment supports concentration instead of fighting it.",
    approach: "We start with how you actually work — not how a catalogue says you should. What do you reach for? What frustrates you? Where does the day break down? Then we design the room, the storage, the lighting, and the systems as one coherent whole.",
    includes: [
      "Workspace layout and flow design",
      "Tool and material storage systems",
      "Lighting for task accuracy and eye comfort",
      "Technology integration — networking, power, display",
      "Acoustic treatment for focus",
      "Inventory and organisation systems",
    ],
  },
  {
    number: "02",
    title: "Live Better",
    tagline: "Storage, kitchens, mudrooms, and living spaces that remove friction from everyday routines.",
    description: "The best homes don't announce their design. They simply feel easy. We study the routines that fill your day — the morning rush, the evening wind-down, the seasonal rotations — and design spaces that support them without friction.",
    approach: "Every family has a rhythm. We observe it, understand it, and then design around it. A mudroom that absorbs the chaos of four people coming home. A kitchen where the most-used tools are always within reach. Storage that remembers so you don't have to.",
    includes: [
      "Room-by-room needs analysis",
      "Storage design and organisation",
      "Kitchen and mudroom function mapping",
      "Closet and pantry systems",
      "Material and finish selection",
      "Furniture layout and sourcing",
    ],
  },
  {
    number: "03",
    title: "Build Better",
    tagline: "Custom millwork, built-ins, and furniture made with honest materials and a long working life.",
    description: "We design and build things that are meant to stay. Built-in shelving that fits the room exactly. A desk shaped to the way you work. Cabinets that will still look right in thirty years.",
    approach: "Craftsmanship is respect — for the material, for the client, and for the person who will maintain it. We choose honest materials that age well, joinery that can be repaired, and finishes that develop patina rather than wear.",
    includes: [
      "Custom millwork and built-ins",
      "Furniture design and fabrication",
      "Material sourcing and specification",
      "Joinery and construction detailing",
      "Finish selection for durability and aging",
      "Integration with room systems and technology",
    ],
  },
  {
    number: "04",
    title: "Think Better",
    tagline: "Planning, automation, workflow, and systems consulting that makes the whole project clearer.",
    description: "Sometimes the most valuable thing is clarity before construction. We help you think through the problem — what matters, what doesn't, what should come first — before a single piece of material is cut.",
    approach: "Systems thinking applied to everyday life. We map your routines, identify the friction, and propose solutions that work as a system rather than a collection of separate fixes. This might mean automation, but it might also mean a better shelf location.",
    includes: [
      "Project scoping and prioritisation",
      "Home and workflow automation design",
      "Systems analysis and documentation",
      "Technology evaluation and recommendation",
      "Project phasing and sequencing",
      "Maintenance and evolution planning",
    ],
  },
];
---

<Layout
  title="Services — Datum Studio"
  description="Datum offers four integrated services: Work Better, Live Better, Build Better, and Think Better. Architecture, craft, and technology for spaces that work beautifully."
  canonical="/services/"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: "Datum Studio Services",
      url: "https://datumstudio.ca/services/",
      description: "Four integrated services for thoughtful spaces: Work Better, Live Better, Build Better, Think Better.",
      mainEntity: {
        "@type": "ItemList",
        itemListElement: services.map((s) => ({
          "@type": "ListItem",
          name: s.title,
          description: s.tagline,
        })),
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: "https://datumstudio.ca" },
        { "@type": "ListItem", position: 2, name: "Services", item: "https://datumstudio.ca/services/" },
      ],
    },
  ]}
>
  <section class="services-hero">
    <div class="section-heading">
      <p class="section-kicker">What we do</p>
      <h2>Defined by outcomes, not trades.</h2>
      <p>One studio thinking across the room, the object, and the technology inside it.</p>
    </div>
  </section>

  {services.map((service) => (
    <section class="service-detail section-pad">
      <div class="service-detail-header">
        <span class="service-detail-number">{service.number}</span>
        <h2>{service.title}</h2>
        <p class="service-detail-tagline">{service.tagline}</p>
      </div>
      <div class="service-detail-body">
        <div class="service-detail-description">
          <p class="service-detail-lead">{service.description}</p>
        </div>
        <div class="service-detail-approach">
          <p class="section-kicker">Our approach</p>
          <p>{service.approach}</p>
        </div>
        <div class="service-detail-includes">
          <p class="section-kicker">What this includes</p>
          <ul>
            {service.includes.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  ))}

  <section class="about-footer section-pad">
    <div class="about-footer-inner">
      <p class="section-kicker">Not sure where to start?</p>
      <h2>Let's figure it out together.</h2>
      <p>Tell us about the space, routine, object, or stubborn problem. Early ideas are welcome; you do not need a finished brief.</p>
      <a class="button button-primary" href="/#contact">Start a conversation <span>↗</span></a>
    </div>
  </section>
</Layout>
