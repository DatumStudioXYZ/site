---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }: { data: CollectionEntry<"projects">["data"] }) => !data.draft);

  return projects.map((project: CollectionEntry<"projects">) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project }: { project: CollectionEntry<"projects"> } = Astro.props;
const { Content } = await render(project);

const heading = project.data.title.replace(/ — Datum Studio$/, "");

const statusLabel: Record<string, string> = {
  "in-progress": "In progress",
  completed: "Completed",
  archived: "Archived",
};

const projectJsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: heading,
  description: project.data.description,
  datePublished: project.data.pubDate.toISOString(),
  dateModified: project.data.updatedDate?.toISOString() ?? project.data.pubDate.toISOString(),
  author: {
    "@type": "Organization",
    name: "Datum Studio",
    url: "https://datumstudio.ca",
  },
  keywords: project.data.tags.join(", "),
  inLanguage: "en",
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://datumstudio.ca",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Projects",
      item: "https://datumstudio.ca/projects/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: heading,
      item: `https://datumstudio.ca/projects/${project.id}/`,
    },
  ],
};
---

<Layout
  title={project.data.title}
  description={project.data.description}
  canonical={`/projects/${project.id}/`}
  jsonLd={[projectJsonLd, breadcrumbJsonLd]}
>
  <article class="project-detail">
    <header class="project-header section-pad">
      <a class="project-back" href="/projects/">&larr; All projects</a>
      <div class="project-header-meta">
        <span class={`project-status project-status--${project.data.status}`}>
          <i></i> {statusLabel[project.data.status]}
        </span>
        <time>{project.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
        {project.data.tags.length > 0 && (
          <span class="article-tags">
            {project.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </span>
        )}
      </div>
      <h1>{heading}</h1>
      <p class="project-description">{project.data.description}</p>
    </header>

    <div class="project-body section-pad">
      <Content />
    </div>

    <footer class="project-footer section-pad">
      <a class="project-back" href="/projects/">&larr; All projects</a>
    </footer>
  </article>
</Layout>
