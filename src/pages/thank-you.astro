---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Thank you — Datum Studio" description="Your message has been received. We will be in touch soon.">
  <section class="section-pad not-found-hero">
    <p class="section-kicker">Message received</p>
    <h1 class="not-found-title">Thank you.</h1>
    <p class="not-found-description">Your message has been sent. We will be in touch — we typically respond within 2 business days.</p>
    <div class="not-found-actions">
      <a class="button button-primary" href="/">Back to home <span>&rarr;</span></a>
      <a class="text-link" href="/articles/">Read articles <span>&rarr;</span></a>
    </div>
  </section>
</Layout>
