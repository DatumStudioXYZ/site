---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }: { data: CollectionEntry<"articles">["data"] }) => !data.draft);

  return articles.map((article: CollectionEntry<"articles">) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article }: { article: CollectionEntry<"articles"> } = Astro.props;
const { Content } = await render(article);

const heading = article.data.title.replace(/ — Datum Studio$/, "");

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: heading,
  description: article.data.description,
  datePublished: article.data.pubDate.toISOString(),
  dateModified: article.data.updatedDate?.toISOString() ?? article.data.pubDate.toISOString(),
  author: {
    "@type": "Organization",
    name: "Datum Studio",
    url: "https://datumstudio.ca",
  },
  publisher: {
    "@type": "Organization",
    name: "Datum Studio",
    url: "https://datumstudio.ca",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `https://datumstudio.ca/articles/${article.id}/`,
  },
  keywords: article.data.tags.join(", "),
  inLanguage: "en",
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://datumstudio.ca",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Articles",
      item: "https://datumstudio.ca/articles/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: heading,
      item: `https://datumstudio.ca/articles/${article.id}/`,
    },
  ],
};
---

<Layout
  title={article.data.title}
  description={article.data.description}
  canonical={`/articles/${article.id}/`}
  ogType="article"
  articlePublished={article.data.pubDate.toISOString()}
  articleTags={article.data.tags}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <article class="article-detail">
    <header class="article-header section-pad">
      <a class="article-back" href="/articles/">&larr; All articles</a>
      <div class="article-header-content">
        <time>{article.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
        {article.data.tags.length > 0 && (
          <span class="article-tags">
            {article.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </span>
        )}
      </div>
      <h1>{heading}</h1>
      <p class="article-description">{article.data.description}</p>
      {article.data.updatedDate && (
        <p class="article-updated">Updated {article.data.updatedDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
      )}
    </header>

    <div class="article-body section-pad">
      <Content />
    </div>

    <footer class="article-footer section-pad">
      <a class="article-back" href="/articles/">&larr; All articles</a>
    </footer>
  </article>
</Layout>
