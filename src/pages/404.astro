---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";

const articles = await getCollection("articles", ({ data }: { data: CollectionEntry<"articles">["data"] }) => !data.draft);
const sortedArticles = articles.sort(
  (a: CollectionEntry<"articles">, b: CollectionEntry<"articles">) => (b.data.updatedDate ?? b.data.pubDate).getTime() - (a.data.updatedDate ?? a.data.pubDate).getTime()
);
const latestArticle = sortedArticles[0] ?? null;

const notes = await getCollection("notes", ({ data }: { data: CollectionEntry<"notes">["data"] }) => !data.draft);
const sortedNotes = notes.sort(
  (a: CollectionEntry<"notes">, b: CollectionEntry<"notes">) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const latestNote = sortedNotes[0] ?? null;

const hasSuggestions = latestArticle || latestNote;
---

<Layout title="Page Not Found — Datum Studio" description="The page you are looking for does not exist.">
  <section class="section-pad not-found-hero">
    <p class="section-kicker">404</p>
    <h1 class="not-found-title">This page does not exist.</h1>
    <p class="not-found-description">The reference point you followed may have moved or been removed. Let us get you back to known ground.</p>
    <div class="not-found-actions">
      <a class="button button-primary" href="/">Back to home <span>&rarr;</span></a>
      <a class="text-link" href="/articles/">Read articles <span>&rarr;</span></a>
    </div>
  </section>

  {hasSuggestions && (
    <section class="section-pad suggested">
      <p class="section-kicker suggested-kicker">Suggested</p>
      <ul class="suggested-list">
        {latestArticle && (
          <li>
            <a href={`/articles/${latestArticle.id}/`} class="suggested-link">
              {latestArticle.data.title}
              <span>{latestArticle.data.description}</span>
            </a>
          </li>
        )}
        {latestNote && (
          <li>
            <a href={`/notes/${latestNote.id}/`} class="suggested-link">
              {latestNote.data.title}
            </a>
          </li>
        )}
        <li><a href="/services/" class="suggested-link-simple">Services</a></li>
        <li><a href="/process/" class="suggested-link-simple">Process</a></li>
        <li><a href="/about/" class="suggested-link-simple">About</a></li>
      </ul>
    </section>
  )}
</Layout>
